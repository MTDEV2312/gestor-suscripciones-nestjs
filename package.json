{
  "name": "gestor-suscripciones-monorepo",
  "private": true,
  "scripts": {
    "dev:backend": "pnpm --filter backend start:dev",
    "dev:frontend": "pnpm --filter frontend dev",
    "dev": "pnpm --filter backend --filter frontend --parallel dev",
    "build:backend": "pnpm --filter backend build",
    "build:frontend": "pnpm --filter frontend build",
    "build": "pnpm --filter backend build && pnpm --filter frontend build",
    "test:backend": "pnpm --filter backend test",
    "test:backend:e2e": "pnpm --filter backend test:e2e"
  }
}
